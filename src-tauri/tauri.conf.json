{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Demeter",
  "version": "2.0.0",
  "identifier": "fr.demeter.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3010",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../frontend/build"
  },
  "app": {
    "windows": [
      {
        "title": "Demeter",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Pierre Couget",
    "copyright": "© 2026 Pierre Couget",
    "category": "Productivity",
    "shortDescription": "Assistant IA orienté RH",
    "longDescription": "Demeter est un assistant IA desktop utilisant les API Albert et Anthropic, conçu pour les professionnels RH.",
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "fr-FR",
        "bannerPath": "installer/banner.bmp",
        "dialogImagePath": "installer/dialog.bmp"
      },
      "nsis": {
        "language": "French",
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "license": "installer/license.html"
      }
    },
    "linux": {
      "deb": {
        "section": "utils"
      }
    }
  }
}