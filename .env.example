# ══════════════════════════════════════════════════════════════════════════════
# Demeter – fichier de configuration
# Copiez ce fichier en .env et ajustez les valeurs selon votre environnement.
# Le .env est chargé au démarrage ; toute modification nécessite un redémarrage.
# Ne commitez pas le .env s'il contient des secrets.
# ══════════════════════════════════════════════════════════════════════════════

# ── Serveur ───────────────────────────────────────────────────────────────────

# Port d'écoute du serveur HTTP interne
API_PORT=45678

# ── RAG — Qdrant (stockage vectoriel local) ───────────────────────────────────

# URL de l'instance Qdrant locale
# Lancer avec : docker run -p 6333:6333 qdrant/qdrant
QDRANT_URL=http://localhost:6333

# Clé d'API Qdrant (optionnelle — laisser vide si Qdrant n'est pas protégé)
# QDRANT_API_KEY=

# ── RAG — Embeddings (via Albert) ─────────────────────────────────────────────

# Modèle d'embedding servi par Albert (doit correspondre à EMBEDDING_DIM)
EMBEDDING_MODEL=BAAI/bge-m3

# Dimension des vecteurs produits par le modèle d'embedding
# bge-m3 → 1024  |  text-embedding-ada-002 → 1536  |  e5-large → 1024
EMBEDDING_DIM=1024

# ── RAG — Reranking et sélection ──────────────────────────────────────────────

# Modèle de reranking (servi par Albert)
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Nombre de chunks récupérés lors de la recherche vectorielle initiale
RAG_TOP_K=20

# Nombre de chunks conservés après reranking (doit être <= RAG_TOP_K)
RAG_TOP_RERANK=5

# Score de similarité minimum pour qu'un chunk soit retenu (entre 0 et 1)
RAG_MIN_SCORE=0.15

# ── LLM ───────────────────────────────────────────────────────────────────────

# Nombre maximum de tokens pour les appels LLM principaux
LLM_MAX_TOKENS=100000

# Nombre maximum de tokens pour la génération de titre de conversation
TITLE_MAX_TOKENS=20

# Nombre maximum de tours dans la boucle agentique MCP
MCP_MAX_TURNS=5

# Taille maximum (en bytes UTF-8) du message utilisateur inclus dans le prompt de titrage
TITLE_TRUNCATE_USER=1200

# Taille maximum (en bytes UTF-8) de la réponse assistant incluse dans le prompt de titrage
TITLE_TRUNCATE_ASSISTANT=600

# ── Timeouts HTTP (en secondes) ───────────────────────────────────────────────

# Appels LLM streamés (génération de réponse principale)
TIMEOUT_LLM_STREAM_SECS=120

# Appels LLM non-streamés (boucle MCP, résumés)
TIMEOUT_LLM_SYNC_SECS=120

# Génération de titre de conversation
TIMEOUT_TITLE_SECS=30

# Recherche et ingestion RAG (Albert search)
TIMEOUT_RAG_SECS=30

# Reranking
TIMEOUT_RERANK_SECS=30

# Résolution des noms de documents
TIMEOUT_DOC_RESOLVE_SECS=10

# Proxy image (avatars, illustrations)
TIMEOUT_IMAGE_PROXY_SECS=15

# Liste des modèles disponibles
TIMEOUT_MODELS_SECS=8


# ── Logs ──────────────────────────────────────────────────────────────────────

# Niveau de log (trace, debug, info, warn, error)
RUST_LOG=demeter=info,tower_http=info
